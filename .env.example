# Common
PROJECT_NAME=connect-core
DEFAULT_COUNTRY=gb

# Control node (future)
CONTROL_NODE_HOST=control.example.com
CONTROL_NODE_SSH_USER=admin

# Worker node (future)
UK_NODE_HOST=uk1.example.com
UK_NODE_SSH_USER=admin

# Xray / VLESS + Reality
REALITY_PRIVATE_KEY=REPLACE_ME
REALITY_PUBLIC_KEY=REPLACE_ME
REALITY_SHORT_ID=0123456789abcdef
REALITY_SERVER_NAME=www.cloudflare.com
REALITY_DEST=www.cloudflare.com:443
VLESS_FLOW=xtls-rprx-vision
VLESS_FP=chrome

# Routing sets
ROUTING_RU_MODE=direct

# Control-plane runtime
ENVIRONMENT=dev
DATABASE_URL=postgresql+psycopg://connect:connect@localhost:5432/connect_control
BASE_SUBSCRIPTION_URL=http://sub.example.com/s
API_BIND_HOST=0.0.0.0
API_BIND_PORT=8080
DIGITALOCEAN_TOKEN=
DO_DEFAULT_REGION=lon1
DO_DEFAULT_IMAGE=ubuntu-24-04-x64
DO_DEFAULT_SIZE=s-1vcpu-1gb

# Telegram admin bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_SSH_KEY_PATH=/opt/connect/.ssh/id_ed25519

# GitHub integration for incident loop
GITHUB_TOKEN=
GITHUB_REPOSITORY=
INCIDENT_AGENT_BACKEND=proposal-only
INCIDENT_STORE_DIR=/opt/connect/shared/incidents
WORKER_REPLACE_OLD_NODE_NAME=connect-worker-uk-1
